# Environment Configuration for HERMES Docker Services
# Copy this file to .env and customize for your setup
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your settings
#   docker-compose up

# ============================================================================
# Dashboard Service Configuration
# ============================================================================

# Port for Flask dashboard (default: 5000)
# Access at http://localhost:<DASHBOARD_PORT>
DASHBOARD_PORT=5000

# Flask environment: development or production
# development: auto-reload on code changes, debug logs
# production: optimized, no debug
FLASK_ENV=development

# Enable debug mode (Flask auto-reload, verbose logging)
DEBUG=true

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# Training Service Configuration (Jupyter Lab)
# ============================================================================

# Port for Jupyter Lab (default: 8888)
# Access at http://localhost:<JUPYTER_PORT>
JUPYTER_PORT=8888

# Jupyter Lab token (leave empty for auto-generated)
# Generated token shown in logs: docker-compose logs training | grep token
JUPYTER_TOKEN=

# ============================================================================
# GPU Configuration
# ============================================================================

# GPU device IDs to expose to containers
# Examples:
#   CUDA_VISIBLE_DEVICES=0          # Use GPU 0 only
#   CUDA_VISIBLE_DEVICES=0,1        # Use GPUs 0 and 1
#   CUDA_VISIBLE_DEVICES=           # Use CPU only (default)
# Leave empty to use CPU
CUDA_VISIBLE_DEVICES=

# ============================================================================
# HuggingFace Configuration
# ============================================================================

# HuggingFace Hub token for downloading models
# Get token at: https://huggingface.co/settings/tokens
# Leave empty if models are already cached or publicly available
HF_TOKEN=

# Model cache directory (inside container)
# Leave default unless you have a specific reason to change
# HF_DATASETS_CACHE=/root/.cache/huggingface/datasets
# HF_HOME=/root/.cache/huggingface

# ============================================================================
# Application Configuration
# ============================================================================

# Base URL for API endpoints (if applicable)
# Used by dashboard to construct API calls
API_BASE_URL=http://localhost:5000

# Git repository URLs (for dashboard metrics)
# These are fetched by the dashboard to show repo stats
GIT_MUSIC_REPO=https://github.com/KudbeeZero/kudbee-music.git
GIT_ENGINE_REPO=https://github.com/KudbeeZero/kudbee-engine.git

# ============================================================================
# Development Settings
# ============================================================================

# Enable hot reload for Flask (auto-restart on file changes)
FLASK_DEBUG=true

# Enable verbose output
VERBOSE=true

# ============================================================================
# Volume Mounts
# ============================================================================

# Note: Volume configuration is in docker-compose.yml
# These settings complement those volumes.
# Data volumes are created automatically if they don't exist.

# ============================================================================
# Network Configuration
# ============================================================================

# Network mode for containers (bridge is default, recommended)
# Leave empty to use docker-compose network settings
# Options: bridge, host, container (see docker-compose docs)
NETWORK_MODE=bridge

# ============================================================================
# Timezone Configuration
# ============================================================================

# Timezone for containers (affects logs, timestamps)
# Examples: UTC, America/New_York, Europe/London
# Leave empty to use system timezone
TZ=UTC

# ============================================================================
# Advanced / Optional Settings
# ============================================================================

# Docker image registry (if using private registry)
# Leave empty for Docker Hub
REGISTRY=

# Image version tag (default: latest)
# Useful for running specific versions
IMAGE_TAG=latest

# Compose project name (affects container names, volumes)
# Default is 'hermes', derived from directory name
# COMPOSE_PROJECT_NAME=hermes
