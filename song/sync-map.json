[
  {
    "text": "Why's it tough for anyone to see?",
    "start": 8.792,
    "end": 11.877,
    "scene": "desk",
    "big": false
  },
  {
    "text": "This isn't some grand philosophy.",
    "start": 11.877,
    "end": 14.62,
    "scene": "desk",
    "big": false
  },
  {
    "text": "Words tossed fast like broken debris,",
    "start": 14.62,
    "end": 17.706,
    "scene": "desk",
    "big": false
  },
  {
    "text": "Knocking the calm right outta the day.",
    "start": 17.706,
    "end": 20.792,
    "scene": "desk",
    "big": false
  },
  {
    "text": "Said something reckless—five minutes prior,",
    "start": 21.82,
    "end": 24.906,
    "scene": "neon",
    "big": false
  },
  {
    "text": "Now flames rise higher like a midnight fryer.",
