    "end": 45.82,
    "scene": "vortex",
    "big": false
  },
  {
    "text": "We go round and round…",
    "start": 46.849,
    "end": 50.62,
    "scene": "corridor",
    "big": true
  },
  {
    "text": "Drop the wrong step, end up underground…",
