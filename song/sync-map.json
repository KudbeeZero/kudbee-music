    "scene": "corridor",
    "big": true
  },
  {
    "text": "Dom Shady hums low with a playful sound.",
    "start": 116.18,
    "end": 120.56,
    "scene": "corridor",
    "big": true
  },
  {
    "text": "Every thought loops back like a hallway bend,",
    "start": 120.87,
